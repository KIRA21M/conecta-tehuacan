# ============================================================
#  Conecta Tehuacán — .gitignore raíz del monorepo
# ============================================================

# ─── Dependencias ────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Variables de entorno (NUNCA subir) ──────────────────────
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
docker/.env

# ─── Next.js (frontend build) ────────────────────────────────
apps/frontend/.next/
apps/frontend/out/
apps/frontend/build/

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ─── Docker volumes locales ──────────────────────────────────
docker/mysql-data/

# ─── Archivos de debug del backend (no deben existir) ────────
apps/backend/check-password.js
apps/backend/check-user.js
apps/backend/test-db.js

# ─── OS / IDE ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ─── Cobertura de tests ──────────────────────────────────────
coverage/
**/coverage/
.nyc_output/

# ─── Temporales ──────────────────────────────────────────────
*.tmp
*.temp
tmp/
