# Database
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT - Access Token (corta duración)
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_ISSUER=conecta-tehuacan
JWT_AUDIENCE=conecta-app

# JWT - Refresh Token (larga duración, secret DIFERENTE)
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
