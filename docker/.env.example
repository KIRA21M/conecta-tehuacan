# ============================================================
#  Conecta Tehuacán — Variables de entorno Docker
#  Copia este archivo como .env en la misma carpeta docker/
#  NUNCA subas el .env real a GitHub
# ============================================================

# ─── MySQL ───────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=conecta_db
MYSQL_USER=conecta_user
MYSQL_PASSWORD=conecta_pass

# ─── Backend ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# JWT Access Token (15 minutos)
JWT_SECRET=dev_access_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_ISSUER=conecta-tehuacan
JWT_AUDIENCE=conecta-app

# JWT Refresh Token (7 días) — secret DIFERENTE al access
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_ENV=development
